{
  "name": "kvorum",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test",
    "postinstall": "prisma generate --schema=libs/db/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=libs/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=libs/db/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=libs/db/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=libs/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=libs/db/prisma/schema.prisma",
    "db:format": "prisma format --schema=libs/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "@nx/eslint": "^22.0.0",
    "@nx/eslint-plugin": "^22.0.0",
    "@nx/js": "22.7.1",
    "@nx/nest": "^22.0.0",
    "@nx/next": "^22.0.0",
    "@nx/vite": "22.7.1",
    "@nx/vitest": "22.7.1",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "20.19.9",
    "@vitest/coverage-v8": "~4.1.0",
    "eslint": "^9.0.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lefthook": "^1.11.0",
    "nx": "^22.0.0",
    "prettier": "~3.6.2",
    "prisma": "^6.19.3",
    "tslib": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.0",
    "vitest": "~4.1.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@prisma/client": "6.19.3",
    "reflect-metadata": "^0.2.2"
  }
}
