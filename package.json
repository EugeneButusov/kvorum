{
  "name": "kvorum",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p apps/api/tsconfig.app.json && tsc --noEmit -p apps/dashboard/tsconfig.json && tsc --noEmit -p apps/indexer/tsconfig.app.json && tsc --noEmit -p apps/ai-worker/tsconfig.app.json && tsc --noEmit -p apps/kvorum-admin/tsconfig.app.json && tsc --noEmit -p libs/domain/tsconfig.lib.json && tsc --noEmit -p libs/db/tsconfig.lib.json && tsc --noEmit -p libs/chain/tsconfig.lib.json && tsc --noEmit -p libs/ai/tsconfig.lib.json",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "postinstall": "prisma generate --schema=libs/db/prisma/schema.prisma",
    "db:generate": "prisma generate --schema=libs/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=libs/db/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=libs/db/prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema=libs/db/prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=libs/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=libs/db/prisma/schema.prisma",
    "db:format": "prisma format --schema=libs/db/prisma/schema.prisma"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "~4.1.0",
    "autoprefixer": "10.4.13",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "lefthook": "^1.11.0",
    "postcss": "8.4.38",
    "prettier": "~3.6.2",
    "prisma": "^6.19.3",
    "tailwindcss": "3.4.3",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.2",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "~4.1.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/client": "6.19.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "next": "~16.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
