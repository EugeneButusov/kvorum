{
  "name": "kvorum",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "pnpm -r run typecheck",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:bundle": "pnpm --filter admin-cli test:bundle",
    "db:migrate": "tsx libs/db/scripts/migrate.mts up",
    "db:migrate:down": "tsx libs/db/scripts/migrate.mts down",
    "db:migrate:ch": "tsx libs/db/scripts/migrate-ch.mts",
    "db:reset": "tsx libs/db/scripts/migrate.mts reset"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/express": "^5.0.6",
    "@types/node": "20.19.9",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "~4.1.0",
    "autoprefixer": "10.4.13",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "lefthook": "^1.11.0",
    "postcss": "8.4.38",
    "prettier": "~3.6.2",
    "supertest": "^7.2.2",
    "tailwindcss": "3.4.3",
    "ts-loader": "^9.5.2",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "~4.1.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.4",
    "@founderpath/kysely-clickhouse": "^1.7.0",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-prometheus": "^0.217.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "clickhouse-migrations": "^1.3.0",
    "ethers": "^6.13.0",
    "ioredis": "^5.10.1",
    "kysely": "^0.29.0",
    "next": "~16.2.3",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0",
