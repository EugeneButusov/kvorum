# ── Database ──────────────────────────────────────────────────────────────────
# POSTGRES_USER/DB/PASSWORD are used by docker-compose.yml to configure the
# Postgres container. DATABASE_URL must stay consistent with these values so
# the Postgres healthcheck and the Prisma connection string never drift.
POSTGRES_USER=kvorum
POSTGRES_DB=kvorum
POSTGRES_PASSWORD=kvorum
POSTGRES_PORT=5432
DATABASE_URL="postgresql://kvorum:kvorum@localhost:5432/kvorum?schema=public&connection_limit=5&pool_timeout=10"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Cursor signing (H3) ───────────────────────────────────────────────────────
# Required by API boot. Replace in production with a real secret from vault.
CURSOR_SECRET=dev-cursor-secret

# ── Anvil (local EVM chain) ───────────────────────────────────────────────────
ANVIL_PORT=8545
# Leave blank for M0 standalone mode (no Alchemy key required).
# M1 reorg test sets this explicitly, e.g.:
# ANVIL_FORK_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ANVIL_FORK_URL=

# ── Indexer integration tests ─────────────────────────────────────────────────
# Set when running apps/indexer/tests/*.integration.spec.ts.
# Requires anvil + postgres up via `docker compose up -d anvil postgres`
# and `pnpm -w db:migrate` against the same DATABASE_URL.
ANVIL_RPC_URL=http://localhost:8545

# ── Application ports ─────────────────────────────────────────────────────────
API_PORT=3001
DASHBOARD_PORT=3000

# ── Observability ─────────────────────────────────────────────────────────────
# Metric name prefix and service identity for OpenTelemetry.
# apps/* set sensible defaults in main.ts but these can be overridden per-process.
OTEL_SERVICE_NAMESPACE=kvorum
OTEL_SERVICE_NAME=api
# Ops HTTP port for /metrics on worker processes (apps/indexer, apps/ai-worker).
# Use a different port per worker when running multiple locally.
OPS_PORT=9091

# ── Future: AI provider (M5) ─────────────────────────────────────────────────
# OPENAI_API_KEY=

# ── API key HMAC peppers (ADR-025 / ADR-028) ─────────────────────────────────
# Base64-encoded 32-byte values. Example generator:
# openssl rand -base64 32
HMAC_PEPPER_CURRENT=
# Optional grace-window pepper used during rotation.
HMAC_PEPPER_PREVIOUS=

# ── Chain config (ADR-028) ────────────────────────────────────────────────────
# JSON blob consumed by libs/chain parseChainConfigFromEnv.
# Real provider URLs / API keys come from the vault (infra/scripts/provision-env.sh)
# and must NEVER be committed. The shape below is illustrative only.
# CHAIN_CONFIG='{"chains":[{"chainId":"0x1","name":"ethereum","headLag":12,"providers":[{"name":"alchemy","url":"https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY","kind":"http","priority":1},{"name":"ankr","url":"https://rpc.ankr.com/eth","kind":"http","priority":2},{"name":"cloudflare","url":"https://cloudflare-eth.com","kind":"http","priority":3}]}]}'
CHAIN_CONFIG=

# ── Indexer tuning knobs ──────────────────────────────────────────────────────
# Lower during a historical backfill to drain the archive faster.
# Defaults: DERIVATION_INTERVAL_MS=5000, INDEXER_CALLDATA_DECODE_INTERVAL_MS=10000
# DERIVATION_INTERVAL_MS=2000
# INDEXER_CALLDATA_DECODE_INTERVAL_MS=2000

# ENS resolver daily cron (default midnight UTC).
# ENS_RESOLVER_CRON='0 0 * * *'

# Set to 'false' during a historical backfill window to disable the live
# EventPoller and avoid the live/backfill cutoff race (see docs/runbooks/m1-backfill.md).
# Default: true (production / existing behavior unchanged).
# INDEXER_LIVE_POLLER_ENABLED=false
