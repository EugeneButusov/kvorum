# ── Database ──────────────────────────────────────────────────────────────────
# POSTGRES_USER/DB/PASSWORD are used by docker-compose.yml to configure the
# Postgres container. DATABASE_URL must stay consistent with these values so
# the Postgres healthcheck and the Prisma connection string never drift.
POSTGRES_USER=kvorum
POSTGRES_DB=kvorum
POSTGRES_PASSWORD=kvorum
POSTGRES_PORT=5432
DATABASE_URL="postgresql://kvorum:kvorum@localhost:5432/kvorum?schema=public&connection_limit=5&pool_timeout=10"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Anvil (local EVM chain) ───────────────────────────────────────────────────
ANVIL_PORT=8545
# Leave blank for M0 standalone mode (no Alchemy key required).
# M1 reorg test sets this explicitly, e.g.:
# ANVIL_FORK_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ANVIL_FORK_URL=

# ── Indexer integration tests ─────────────────────────────────────────────────
# Set when running apps/indexer/tests/*.integration.spec.ts.
# Requires anvil + postgres up via `docker compose up -d anvil postgres`
# and `pnpm -w db:migrate` against the same DATABASE_URL.
ANVIL_RPC_URL=http://localhost:8545

# ── Application ports ─────────────────────────────────────────────────────────
API_PORT=3001
DASHBOARD_PORT=3000

# ── Observability ─────────────────────────────────────────────────────────────
# Metric name prefix and service identity for OpenTelemetry.
# apps/* set sensible defaults in main.ts but these can be overridden per-process.
OTEL_SERVICE_NAMESPACE=kvorum
OTEL_SERVICE_NAME=api
# Ops HTTP port for /metrics on worker processes (apps/indexer, apps/ai-worker).
# Use a different port per worker when running multiple locally.
OPS_PORT=9091

# ── Future: AI provider (M5) ─────────────────────────────────────────────────
# OPENAI_API_KEY=

# ── API key HMAC peppers (ADR-025 / ADR-028) ─────────────────────────────────
# Base64-encoded 32-byte values. Example generator:
# openssl rand -base64 32
HMAC_PEPPER_CURRENT=
# Optional grace-window pepper used during rotation.
HMAC_PEPPER_PREVIOUS=
