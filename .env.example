# ── Database ──────────────────────────────────────────────────────────────────
# POSTGRES_USER/DB/PASSWORD are used by docker-compose.yml to configure the
# Postgres container. DATABASE_URL must stay consistent with these values so
# the Postgres healthcheck and the Prisma connection string never drift.
POSTGRES_USER=kvorum
POSTGRES_DB=kvorum
POSTGRES_PASSWORD=kvorum
POSTGRES_PORT=5432
DATABASE_URL="postgresql://kvorum:kvorum@localhost:5432/kvorum?schema=public&connection_limit=5&pool_timeout=10"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379

# ── Anvil (local EVM chain) ───────────────────────────────────────────────────
ANVIL_PORT=8545
# Leave blank for M0 standalone mode (no Alchemy key required).
# M1 reorg test sets this explicitly, e.g.:
# ANVIL_FORK_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ANVIL_FORK_URL=

# ── Application ports ─────────────────────────────────────────────────────────
API_PORT=3001
DASHBOARD_PORT=3000

# ── Future: AI provider (M5) ─────────────────────────────────────────────────
# OPENAI_API_KEY=

# ── Future: HMAC signing ──────────────────────────────────────────────────────
# HMAC_SECRET=
