{
  "name": "admin-cli",
  "version": "0.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "build": "node build.mjs",
    "build:dev": "node build.mjs",
    "start": "node ../../dist/apps/admin-cli/main.js",
    "start:dev": "pnpm run build:dev && node ../../dist/apps/admin-cli/main.js",
