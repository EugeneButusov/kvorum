exports[`admin-cli help snapshots > top-level --help 1`] = `
"Usage: admin-cli [options] [command]

Kvorum operator administration CLI

Options:
  -V, --version          output the version number
  -f, --format <format>  output format: human or json (default: "human")
  -h, --help             display help for command

Commands:
  actors                 Actor management
  ai                     AI feature management
  audits                 Audit log access
  backfill               Backfill management
  daos                   DAO management
  derive                 Derived data management
  dlq                    Dead-letter queue management
  keys                   API key management
  maintenance            Maintenance mode management
  status [options]       Show system status
  snapshot               Voting power snapshot operations
  users                  User management
  help [command]         display help for command
"
`;

exports[`admin-cli help snapshots > users --help 1`] = `
"Usage: admin-cli users [options] [command]

User management

Options:
  -h, --help                  display help for command

Commands:
  list [options]              List users
  ban [options] <user_id>     Ban a user (destructive)
  delete [options] <user_id>  Delete a user account (destructive)
  create [options]            Create a new user account
  update [options] <user_id>  Update a user account
  help [command]              display help for command
"
`;
