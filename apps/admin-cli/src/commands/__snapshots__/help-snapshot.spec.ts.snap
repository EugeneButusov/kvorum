List audit log entries

Options:
  --format <format>  output format: human or json
  -h, --help         display help for command
"
`;

exports[`admin-cli help snapshots > backfill --help 1`] = `
"Usage: admin-cli backfill [options] [command]

Backfill management

Options:
  -h, --help                        display help for command

Commands:
  start [options] <source_type>     Start a backfill for a DAO source
  catch-up [options] <source_type>  Run startup-style gap fill for an existing
                                    DAO source
  help [command]                    display help for command
"
`;

exports[`admin-cli help snapshots > daos --help 1`] = `
"Usage: admin-cli daos [options] [command]

DAO management

Options:
  -h, --help            display help for command

Commands:
  add [options] <slug>  Register a new DAO
  source                DAO source management
  help [command]        display help for command
"
`;

exports[`admin-cli help snapshots > daos source --help 1`] = `
"Usage: admin-cli daos source [options] [command]

DAO source management

Options:
  -h, --help                        display help for command

Commands:
  add [options] <dao_slug>          Add a data source to a DAO
  update [options] <dao_source_id>  Update a DAO source configuration
  delete [options] <dao_source_id>  Delete a DAO source (destructive)
  help [command]                    display help for command
"
`;

exports[`admin-cli help snapshots > derive --help 1`] = `
"Usage: admin-cli derive [options] [command]

Derived data management

Options:
  -h, --help                               display help for command

Commands:
  replay [options] <dao_source_id>         Replay derivation for a DAO source (destructive)
  verify [options] <proposal_external_id>  Verify derived data for a proposal
  help [command]                           display help for command
"
`;

exports[`admin-cli help snapshots > dlq --help 1`] = `
"Usage: admin-cli dlq [options] [command]

Dead-letter queue management

Options:
  -h, --help                 display help for command

Commands:
  list [options]             List DLQ entries
  retry [options] <dlq_id>   Retry a DLQ entry
  accept [options] <dlq_id>  Accept (discard) a DLQ entry with a recorded reason
  help [command]             display help for command
"
`;

exports[`admin-cli help snapshots > keys --help 1`] = `
