// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`admin-cli help snapshots > actors --help 1`] = `
"Usage: admin-cli actors [options] [command]

Actor management

Options:
  -h, --help                                             display help for command

Commands:
  merge [options] <primary_address> <secondary_address>  Merge two actor identities (destructive)
  show [options] <address>                               Show actor identity, addresses, merge state, and inbound redirects
  address                                                Actor address management
  help [command]                                         display help for command
"
`;

exports[`admin-cli help snapshots > actors merge --help 1`] = `
"Usage: admin-cli actors merge [options] <primary_address> <secondary_address>

Merge two actor identities (destructive)

Options:
  --reason <text>    human-readable rationale for the merge (required, max 4KB)
  --confirm          confirm destructive operation
  --production       acknowledge production environment
  --dry-run          show what would happen without making changes
  --format <format>  output format: human or json
  -h, --help         display help for command
"
`;

exports[`admin-cli help snapshots > actors show --help 1`] = `
"Usage: admin-cli actors show [options] <address>

Show actor identity, addresses, merge state, and inbound redirects

Options:
  --format <format>  output format: human or json
  -h, --help         display help for command
"
`;

exports[`admin-cli help snapshots > ai --help 1`] = `
"Usage: admin-cli ai [options] [command]

AI feature management

Options:
  -h, --help                                         display help for command

Commands:
  disable [options] <feature>                        Disable an AI feature
  enable [options] <feature>                         Enable an AI feature
  cap                                                AI spending cap management
  regenerate [options] <feature> <entity_reference>  Regenerate AI output for an entity
  help [command]                                     display help for command
"
`;

exports[`admin-cli help snapshots > audits --help 1`] = `
