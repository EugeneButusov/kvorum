# Dashboard server-side config (never expose as NEXT_PUBLIC_*).
# The same-origin BFF (app/api/kv/[...path]) uses these to reach the token-gated API;
# the browser never holds a key. See ADR-084.

# Base URL of the Kvorum read API.
KVORUM_API_URL=http://localhost:3001

# Server-side API key the BFF attaches to reads (Authorization: Bearer …).
# In production this comes from the secrets vault (ADR-028); when auth ships, the BFF
# switches to the session-provisioned kv_dashboard_* key (ADR-035).
KVORUM_API_KEY=
