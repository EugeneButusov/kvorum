# Dashboard server-side config (never expose as NEXT_PUBLIC_*).
# The same-origin BFF (app/api/[...path]) uses this to reach the API; the browser
# never talks to the API directly. See ADR-084.

# Base URL of the backend read API.
BACKEND_API_URL=http://localhost:3001

# Note: the read API is currently open (no key). When the auth backend lands, the BFF
# attaches a server-side / session key at that seam (secrets via the vault, ADR-028) —
# never a NEXT_PUBLIC_* value.

# --- Public (client) config — safe to expose ---
# Plausible Cloud domain for cookieless analytics. Leave unset in dev / preview / CI so no
# pageviews are emitted; set to the deployed domain in production (e.g. kvorum.watch).
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
